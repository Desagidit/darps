# Copy this file to `.env` and fill in whichever key your provider needs.
# Real shell environment variables take precedence over anything here.

# For provider: anthropic
ANTHROPIC_API_KEY=sk-ant-...

# For provider: openai
# OPENAI_API_KEY=sk-...

# For provider: openai_compatible (any other OpenAI-style server)
# LLM_API_KEY=...

# Local providers (ollama, lmstudio) need no key.
